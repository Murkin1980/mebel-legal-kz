# Supabase Configuration
# Получить значения из Supabase Dashboard: https://supabase.com/dashboard

# URL проекта Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (публичный ключ, используется в браузере)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (ТОЛЬКО серверные операции, НЕ в браузере!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Среда (demo, pilot, staging, production)
NEXT_PUBLIC_APP_ENV=demo

# Базовый URL приложения
NEXT_PUBLIC_APP_URL=http://localhost:3000
